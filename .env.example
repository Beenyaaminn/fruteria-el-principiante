# Database (PostgreSQL para producción)
# En Neon: https://neon.tech - crear DB gratuita
# Formato: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secreto para firmar las sesiones JWT (NextAuth / jose)
# Generar uno nuevo: openssl rand -base64 32
SESSION_SECRET="cambia-esto-en-produccion-usa-openssl-rand-base64-32"

# Node env
NODE_ENV="production"
